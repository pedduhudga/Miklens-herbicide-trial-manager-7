# Copy this file to .env and fill in your Firebase project values.
# These are baked into the build at compile time so the Live QR page
# works for anyone who scans the QR — even without logging into the app.
#
# Set these same variables in Vercel → Project → Settings → Environment Variables

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
